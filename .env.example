# ============================
# eino-loop 配置文件（示例）
# 复制为 .env 并填入实际值
# ============================

# ---- 仓库配置 ----
EINO_LOOP_REPO_ROOT=/path/to/your/repos
EINO_LOOP_TARGET_BRANCH=master
EINO_LOOP_FIX_BRANCH_TPL=fix/slog-withcontext-{date}

# ---- 扫描配置 ----
EINO_LOOP_SCAN_INTERVAL=1h
EINO_LOOP_MAX_REPOS=50
EINO_LOOP_MAX_RETRIES=3
EINO_LOOP_DRY_RUN=false

# ---- 飞书配置 ----
EINO_LOOP_FEISHU_ENABLED=false
EINO_LOOP_FEISHU_CHAT_ID=
EINO_LOOP_FEISHU_CLI_PATH=lark-cli
EINO_LOOP_FEISHU_DOC_SPACE=
